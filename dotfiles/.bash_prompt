# Heavily inspifore_red by @necolas’s prompt: https://github.com/necolas/dotfiles
export TERM='xterm-256color';

tput sgr0

set_prompt() {
  local EXIT="$?"

  local bold=$(tput bold)
  local reset=$(tput sgr0)

  # Compare to https://i.sstatic.net/a2S4s.png
  local fore_black=$(tput setaf 0)
  local fore_blue=$(tput setaf 32)
  local fore_cyan=$(tput setaf 37)
  local fore_green=$(tput setaf 70)
  local fore_orange=$(tput setaf 202)
  local fore_purple=$(tput setaf 125)
  local fore_red=$(tput setaf 160)
  local fore_violet=$(tput setaf 97)
  local fore_white=$(tput setaf 253)
  local fore_yellow=$(tput setaf 136)
  local back_black=$(tput setab 0)
  local back_blue=$(tput setab 32)
  local back_cyan=$(tput setab 37)
  local back_green=$(tput setab 70)
  local back_orange=$(tput setab 202)
  local back_purple=$(tput setab 125)
  local back_red=$(tput setab 124)
  local back_violet=$(tput setab 97)
  local back_white=$(tput setab 15)
  local back_yellow=$(tput setab 136)

  local branchColor=""
	local branchName=""
	local branchIcon=""

	PS1="\[\033]0;\w\007\]"; # working directory base name as window title
  PS1+="\[${bold}${fore_violet}\]\w\[${reset}\]"; # working directory full path

	if git rev-parse --is-inside-work-tree &>/dev/null; then
  	# Uncommitted changes in the index.
  	if ! $(git diff --quiet --ignore-submodules --cached); then
  		branchColor=${fore_red}
  		branchIcon="󱓊"
  	# Check for unstaged changes.
  	elif ! $(git diff-files --quiet --ignore-submodules --); then
      branchColor=${fore_orange}
      branchIcon="󱓍"
  	# Check for untracked files.
  	elif [ -n "$(git ls-files --others --exclude-standard)" ]; then
  	  branchColor=${fore_green}
  	  branchIcon="󰘬"
  	else
  	  branchColor=${fore_green}
  	  branchIcon="󱓏"
  	fi

    # Named branch
  	if branchName=$(git symbolic-ref --quiet --short HEAD 2>/dev/null); then
  	  :
    # Detached HEAD on a tag or ref
    elif branchName=$(git describe --all --exact-match HEAD 2>/dev/null); then
      :
    # Commit-Hash only
    elif branchName=$(git rev-parse --short HEAD 2>/dev/null); then
      :
    # 🤷‍♂️
    else
        branchName="🤷‍♂️"
    fi

    PS1+=" \[${fore_white}\]${branchIcon}\[${branchColor}\]${branchName}\[${reset}\]"
	fi

  # Use different color for prompt when last exit returned exitcode != 0
  if [ $EXIT -ne 0 ]; then
    PS1+="\[${fore_red}\] ❯ \[${reset}\]"
  else
    PS1+="\[${fore_white}\] ❯ \[${reset}\]"
  fi
}

export PROMPT_COMMAND=set_prompt
export PROMPT_DIRTRIM=4

PS2="\[${bold}\]\[${fore_violet}\]→ \[${reset}\]";
export PS2;
