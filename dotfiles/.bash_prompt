# Heavily inspired by @necolas’s prompt: https://github.com/necolas/dotfiles
export TERM='xterm-256color';

# Compare to https://i.sstatic.net/a2S4s.png
bold=$(tput bold);
reset=$(tput sgr0);
black=$(tput setaf 0);
blue=$(tput setaf 32);
cyan=$(tput setaf 37);
green=$(tput setaf 64);
orange=$(tput setaf 202);
purple=$(tput setaf 125);
red=$(tput setaf 124);
violet=$(tput setaf 97);
white=$(tput setaf 15);
yellow=$(tput setaf 136);

prompt_git() {
	local color='';
	local branchName='';

	# Early return if this isn't a git repository
	git rev-parse --is-inside-work-tree &>/dev/null || return;

	# Uncommitted changes in the index.
	if ! $(git diff --quiet --ignore-submodules --cached); then
		color=${red}
	# Check for unstaged changes.
	elif ! $(git diff-files --quiet --ignore-submodules --); then
    color=${orange}
	# Check for untracked files.
	elif [ -n "$(git ls-files --others --exclude-standard)" ]; then
	  color=${green}
	  # TODO mark untracked
	else
	  color=${green}
	fi

  # Named branch
	if branchName=$(git symbolic-ref --quiet --short HEAD 2>/dev/null); then
      :
  # Detached HEAD on a tag or ref
  elif branchName=$(git describe --all --exact-match HEAD 2>/dev/null); then
      :
  # Commit-Hash only
  elif branchName=$(git rev-parse --short HEAD 2>/dev/null); then
      :
  # 🤷‍♂️
  else
      branchName="🤷‍♂️"
  fi

	echo -e "@${color}${branchName}${reset}";
}

tput sgr0
PS1="\[\033]0;\007\]";
PS1+="\[${bold}\]\[${violet}\]\w\[${reset}\]"; # working directory full path
PS1+="\$(prompt_git)"; # Git repository details
PS1+="\[${white}\]\$ \[${reset}\]"; # `$` (and reset color)
export PS1;

PS2="\[${bold}\]\[${violet}\]→ \[${reset}\]";
export PS2;

export PROMPT_DIRTRIM=4
