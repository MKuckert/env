#!/usr/bin/env bash

# Brew installed binaries
export PATH="$(brew --prefix)/bin:$PATH"
export PATH="$(brew --prefix coreutils)/libexec/gnubin:$PATH"

# llama.cpp
export PATH="$HOME/private/dev/llama.cpp/build/bin:$PATH"

# timelog
export PATH="$HOME/private/dev/timelog/bin:$PATH"

# cherri
export PATH="$HOME/private/dev/cherri:$PATH"

# tools from this repository
## backgrounded processes
export PATH="$HOME/env/background-run:$PATH"
## docker sandboxes
export PATH="$HOME/env/docker/sandbox:$PATH"
