#!/usr/bin/env bash
export EDITOR='vim'

# Increase Bash history size, default is 500
export HISTSIZE='32768';
export HISTFILESIZE="${HISTSIZE}";
# Omit duplicates and commands that begin with a space from history.
export HISTCONTROL='ignoreboth';

# Prefer US English and use UTF-8.
export LC_ALL=en_US.UTF-8
export LANG=en_US.UTF-8

# No macos "use zsh" warning
export BASH_SILENCE_DEPRECATION_WARNING=1

# Disable some analytics
export HOMEBREW_NO_ANALYTICS=1
export FASTLANE_OPT_OUT_USAGE=1
export DOTNET_CLI_TELEMETRY_OPTOUT=1
export NUKE_TELEMETRY_OPTOUT=1
export VCPKG_DISABLE_METRICS=1

# Make brew less verbose about potential env vars
export HOMEBREW_NO_ENV_HINTS=1

# Enables the websearch tool in opencode. See https://opencode.ai/docs/tools/#websearch
export OPENCODE_ENABLE_EXA=1
