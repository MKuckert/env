#define name dev-stop
#define glyph noteText
#define color red

#include 'lib/base.cherri'
#include 'lib/appids.cherri'

quitApp(APPID_ZED)
hideApp(APPID_TERMINAL)
quitApp(APPID_TIMELOGGER)

runShellScript('
source ~/.bash_profile

# Unload model but do not stop ai runner
ollama stop tiny

# Stop container environment
colima stop docker
colima stop containerd
colima stop ai
')

paste gobble
