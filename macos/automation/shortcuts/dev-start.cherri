#define name dev-start
#define glyph noteText
#define color green

#include 'lib/base.cherri'
#include 'lib/appids.cherri'
#include 'lib/focus.cherri'

runShellScript("timelog start dev", nothing)

openApp(APPID_ZED)
openApp(APPID_TERMINAL)
openApp(APPID_TIMELOGGER)

// Start ai runner
runShellScript("brew services start ollama", nothing)
wait(3)
runShellScript("ollama run tiny --keepalive 24h \"\"", nothing)

// Start container environment
runShellScript("colima start docker", nothing)
runShellScript("colima start containerd", nothing)
runShellScript("colima start ai", nothing)

paste persist_focus
paste gobble
