#define name dev-start
#define glyph noteText
#define color green

#include 'lib/base.cherri'
#include 'lib/appids.cherri'
#include 'lib/focus.cherri'

runShellScript('
source ~/.bash_profile
timelog start dev

# Start ai runner
brew services start ollama
sleep 3
ollama run tiny --keepalive 24h ""

# Start container environment
colima start docker
colima start containerd
colima start ai
')

openApp(APPID_ZED)
openApp(APPID_TERMINAL)
openApp(APPID_TIMELOGGER)

paste persist_focus
paste gobble
