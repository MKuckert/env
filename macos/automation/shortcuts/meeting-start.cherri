#define name meeting-start
#define glyph chatBubble
#define color green

#include 'lib/base.cherri'
#include 'lib/appids.cherri'
#include 'lib/focus.cherri'

runShellScript("timelog start meeting", nothing)

pause()

// Doesn't currently emit a correct action as of cherry v2.1.1
// See https://github.com/electrikmilk/cherri/issues/166
hideAllApps(APPID_TEAMS)

openApp(APPID_TEAMS)

paste persist_focus
paste gobble
